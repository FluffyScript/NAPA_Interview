{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=mydb;Username=myuser;Password=mypassword"
  },
  "Monitoring": {
    "CollectionIntervalSeconds": 15,
    "LongRunningQueryThresholdSeconds": 30,
    "MinDeadTuplesThreshold": 100
  }
}
